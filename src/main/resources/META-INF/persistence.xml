<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="rcosdPersistenceUnit" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.rocs.osd.model.login.Login</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="oracle.jdbc.driver.OracleDriver" />

            <property name="jakarta.persistence.jdbc.url" value="jdbc:oracle:thin:@localhost:1521:oracleDB" />
            <property name="jakarta.persistence.jdbc.user" value="rcosd" />
            <property name="jakarta.persistence.jdbc.password" value="Changeme0" />

            <property name="hibernate.dialect" value="org.hibernate.dialect.OracleDialect" />

            <property name="hibernate.hbm2ddl.auto" value="update" />

            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="false" />
            <property name="hibernate.highlight_sql" value="true" />

            <property name="hibernate.jdbc.batch_size" value="20" />
            <property name="hibernate.order_inserts" value="true" />
            <property name="hibernate.order_updates" value="true" />
        </properties>

    </persistence-unit>
</persistence>