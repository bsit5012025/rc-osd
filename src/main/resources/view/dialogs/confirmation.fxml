<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="root"
           styleClass="mainContainer"
           stylesheets="@../../styles/dialog/confirmation.css"
           xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           fx:controller="org.rocs.osd.controller.dialog.ConfirmationDialogController">

    <VBox styleClass="popup-window">

        <HBox styleClass="title-bar">
            <Button onAction="#handleCancel" styleClass="icon-button">
                <graphic>
                    <ImageView fitHeight="15" fitWidth="15" preserveRatio="true">
                        <image>
                            <Image url="@../../assets/X_Button.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
        </HBox>

        <VBox styleClass="content-body">

            <Label fx:id="messageLine1" styleClass="prompt-text"/>
            <Label fx:id="messageLine2" styleClass="prompt-text"/>

            <HBox styleClass="button-group">

                <Button fx:id="cancelButton"
                        text="Cancel"
                        onAction="#handleCancel"
                        styleClass="confirm-button"/>

                <Button fx:id="confirmButton"
                        text="Confirm"
                        onAction="#handleConfirm"
                        styleClass="confirm-button"/>

            </HBox>
        </VBox>
    </VBox>
</StackPane>
