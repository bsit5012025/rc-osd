<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="requestCard"
      xmlns="http://javafx.com/javafx/1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.rocs.osd.controller.appeal.AppealModalController">


    <HBox styleClass="cardTopRow">
        <VBox styleClass="infoSection" HBox.hgrow="ALWAYS">
            <HBox styleClass="labelRow">
                <Label styleClass="boldLabel" text="Student ID: " />
                <Label fx:id="studentIdLabel" styleClass="dataLabel"/>
            </HBox>

            <HBox styleClass="labelRow">
                <Label styleClass="boldLabel" text="Student Name: " />
                <Label fx:id="studentNameLabel" styleClass="dataLabel"/>
            </HBox>

            <VBox fx:id="expandedSection" styleClass="expandedSection">
                <HBox styleClass="labelRow">
                    <Label styleClass="boldLabel" text="Offense: " />
                    <Label fx:id="offenseLabel" styleClass="dataLabel"/>
                </HBox>
                <Label styleClass="boldLabel" text="Reason for Appeal: " />
                <Label fx:id="reasonLabel" styleClass="reasonText" wrapText="true"/>
            </VBox>
        </VBox>

        <VBox alignment="TOP_RIGHT">
            <Button fx:id="arrowButton" styleClass="arrowButton">
                <graphic>
                    <ImageView fx:id="arrowIcon" fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                        <Image url="@../../assets/downButton.png"/>
                    </ImageView>
                </graphic>
            </Button>
        </VBox>
    </HBox>

    <HBox alignment="CENTER_RIGHT" styleClass="actionRow">
        <Button fx:id="denyButton" styleClass="denyButton" text="Deny"/>
        <Button fx:id="approveButton" styleClass="approveButton" text="Approve">
            <HBox.margin>
                <Insets left="10.0"/>
            </HBox.margin>
        </Button>
    </HBox>

    <VBox fx:id="popupBox" alignment="CENTER" spacing="5"
          style="-fx-background-color: #DDE1EB; -fx-padding: 10; -fx-background-radius: 8;"
          visible="false">
        <Label fx:id="popupLabel" style="-fx-font-weight: bold; -fx-text-fill: #000080;"/>
    </VBox>
</VBox>
