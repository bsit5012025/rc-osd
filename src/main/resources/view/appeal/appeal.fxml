<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="org.rocs.osd.controller.appeal.AppealController"
            styleClass="rootContainer"
            stylesheets="@../../styles/request/request.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml">

    <center>
        <VBox styleClass="mainWrapper">
            <HBox styleClass="headerContainer">
                <Label styleClass="headerText" text="APPEALS" />
            </HBox>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        styleClass="requestsScrollPane"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="listContainer" styleClass="listContainer" />
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
