<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="dashboardRoot"
            stylesheets="@../../styles/dashboard/dashboard.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.rocs.osd.controller.dashboard.CenterDashboardController">

    <center>
        <StackPane fx:id="mainContentWrapper" styleClass="mainContentWrapper">
            <VBox styleClass="contentArea">
                <HBox styleClass="statsRow">
                    <VBox styleClass="statCard" HBox.hgrow="ALWAYS">
                        <Label styleClass="statTitle" text="Total Violations" />
                        <Label fx:id="totalViolationLabel" styleClass="statValue" text="200" />
                        <ProgressBar maxWidth="1200" progress="0.85" />
                    </VBox>
                    <VBox styleClass="statCard" HBox.hgrow="ALWAYS">
                        <Label styleClass="statTitle" text="Pending Appeals" />
                        <Label fx:id="pendingAppealsLabel" styleClass="statValue" text="0" />
                        <ProgressBar maxWidth="1200" progress="0.25" />
                    </VBox>
                    <VBox styleClass="statCard" HBox.hgrow="ALWAYS">
                        <Label styleClass="statTitle" text="Offenses Today" />
                        <Label styleClass="statValue" text="25" />
                        <ProgressBar maxWidth="1200" progress="0.45" />
                    </VBox>
                    <VBox styleClass="dateCard" HBox.hgrow="ALWAYS">
                        <HBox styleClass="dateContent">
                            <VBox styleClass="dateVerticalStack">
                                <Label styleClass="dateMonth" text="FEB" />
                                <Label styleClass="dateDay" text="04">
                                    <VBox.margin><Insets left="-5.0" top="10.0" /></VBox.margin>
                                </Label>
                                <Label styleClass="dateWeek" text="TUE">
                                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                                </Label>
                            </VBox>
                            <VBox styleClass="dateSeparator" />
                            <Label styleClass="timeText" text="05:28 PM" />
                        </HBox>
                    </VBox>
                </HBox>

                <VBox styleClass="panel">
                    <Label styleClass="panelTitle" text="Most Frequent Offenses Committed" />
                    <VBox styleClass="offenseList">
                        <HBox styleClass="offenseRow">
                            <Label styleClass="offenseName" text="Cheating" />
                            <ProgressBar maxWidth="1200" progress="0.75" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox styleClass="offenseRow">
                            <Label styleClass="offenseName" text="Punching" />
                            <ProgressBar maxWidth="1200" progress="0.65" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox styleClass="offenseRow">
                            <Label styleClass="offenseName" text="Improper Uniform" />
                            <ProgressBar maxWidth="1200" progress="0.55" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox styleClass="offenseRow">
                            <Label styleClass="offenseName" text="Vaping" />
                            <ProgressBar maxWidth="1200" progress="0.42" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox styleClass="offenseRow">
                            <Label styleClass="offenseName" text="PDA" />
                            <ProgressBar maxWidth="1200" progress="0.82" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                </VBox>

                <VBox styleClass="panel" VBox.vgrow="ALWAYS">
                    <Label styleClass="panelTitle" text="Recent Violations" />
                    <TableView VBox.vgrow="ALWAYS" fx:id="recentViolations" >
                        <columns>
                            <TableColumn fx:id="studentIdColumn" text="Student ID" />
                            <TableColumn fx:id="studentNameColumn" text="Student Name" />
                            <TableColumn fx:id="levelOfOffenseColumn" text="Level of Offense" />
                            <TableColumn fx:id="offenseTypeColumn" text="Offense Type" />
                            <TableColumn fx:id="dateColumn" text="Date" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
