<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="rootContainer"
            stylesheets="@../../styles/request/request.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.rocs.osd.controller.dashboard.DashboardController">

    <center>
        <VBox styleClass="mainWrapper">
            <HBox styleClass="headerContainer">
                <Label styleClass="headerText" text="REQUESTS">
                    <HBox.margin>
                        <Insets left="8.0" />
                    </HBox.margin>
                </Label>
            </HBox>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        styleClass="requestsScrollPane"
                        VBox.vgrow="ALWAYS">

                <VBox fx:id="listContainer" styleClass="listContainer">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>

            </ScrollPane>
        </VBox>
    </center>
</BorderPane>